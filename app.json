{
  "expo": {
    "name": "Daily Pocket",
    "slug": "daily-pocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dailypocket",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/myicon/daily_pocket_icon.png",
      "bundleIdentifier": "com.anonymous.daily-pocket",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Camera roll access required for profile image upload.",
        "NSCameraUsageDescription": "Camera access require for profile image upload."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.dailypocket",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
